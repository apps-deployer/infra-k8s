auth:
  username: deployments-service
  password: {{ requiredEnv "PG_DEPLOYMENTS_PASSWORD" | quote }}
  postgresPassword: {{ requiredEnv "PG_DEPLOYMENTS_ADMIN_PASSWORD" | quote }}

primary:
  persistence:
    enabled: true
    size: 1Gi
    storageClass: yc-network-hdd

resources:
  requests:
    memory: 256Mi
    cpu: 100m
  limits:
    memory: 512Mi
    cpu: 500m
